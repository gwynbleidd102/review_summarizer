{
  "manifest_version": 3,
  "name": "Review Summarizer",
  "version": "1.0.0",
  "description": "Автоматическая суммаризация отзывов с помощью NLP и LLM",
  "permissions": ["activeTab"],
  "host_permissions": ["http://localhost:8000/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.google.com/maps/*",
        "*://*.google.ru/maps/*",
        "*://*.yandex.ru/maps/*",
        "*://*.yandex.com/maps/*"
      ],
      "js": ["config/sites.js", "content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
